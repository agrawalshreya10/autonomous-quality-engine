# Autonomous Quality Engine — template (copy to .env and adjust for local use)

# Base URL (Defaults to public demo if unset in .env)
BASE_URL=https://opensource-demo.orangehrmlive.com

# --- Local Environment Examples (Uncomment and move to .env to use) ---
# BASE_URL=http://ohrm.test
# BASE_URL=http://127.0.0.1:8888/orangehrm

# Security: Ignore TLS errors for local self-signed certificates
IGNORE_HTTPS_ERRORS=true

# Execution Settings
BROWSER=chromium
HEADLESS=true
TIMEOUT_MS=15000

# Credentials (Defaults match public demo; override in .env for local)
ORANGEHRM_USER=Admin
ORANGEHRM_PASSWORD=admin123

# AI audit: explicit provider — ollama (default) or gemini (requires GEMINI_API_KEY)
AI_PROVIDER=ollama
# GEMINI_API_KEY=AIzaSy...