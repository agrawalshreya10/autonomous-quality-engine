# Autonomous Quality Engine — template (copy to .env and adjust for local use)
#
# This repository is the test automation project (AQE). Variable names such as
# BASE_URL and ORANGEHRM_* refer to the OrangeHRM system under test (demo or your
# own instance), not to separate “Autonomous Quality Engine” product URLs.

# Base URL (Defaults to public demo if unset in .env)
BASE_URL=https://opensource-demo.orangehrmlive.com

# --- Local Environment Examples (Uncomment and move to .env to use) ---
# BASE_URL=http://ohrm.test
# BASE_URL=http://127.0.0.1:8888/orangehrm

# WARNING — IGNORE_HTTPS_ERRORS: When true, the browser disables TLS certificate
# verification for the OrangeHRM origin. That is insecure (MITM risk) and must
# never be used against production or untrusted hosts. Use true only for local
# dev with self-signed HTTPS (e.g. MAMP/ohrm.test). Public demo and normal HTTPS
# should keep the safe default below.

# Safe default (matches application default in config/settings.py when unset)
IGNORE_HTTPS_ERRORS=false

# Execution Settings
BROWSER=chromium
HEADLESS=true
TIMEOUT_MS=15000

# Credentials (Defaults match public demo; override in .env for local)
ORANGEHRM_USER=Admin
ORANGEHRM_PASSWORD=admin123

# AI audit: explicit provider — ollama (default) or gemini (requires GEMINI_API_KEY)
AI_PROVIDER=ollama
# GEMINI_API_KEY=AIzaSy...